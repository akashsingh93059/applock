<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="20dp">

    <EditText android:id="@+id/etTplName"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:hint="Template name (e.g. Deep Work)"
        android:textColor="#1A1A2E" android:textSize="14sp"
        android:inputType="text" android:layout_marginBottom="12dp"/>

    <EditText android:id="@+id/etTplIcon"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:hint="Icon emoji (e.g. 🧠)"
        android:textColor="#1A1A2E" android:textSize="20sp"
        android:inputType="text" android:layout_marginBottom="12dp"/>

    <TextView android:id="@+id/tvTplDuration"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="25 min" android:textColor="#1A1A2E"
        android:textSize="16sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>

    <SeekBar android:id="@+id/sbTplDuration"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:max="115" android:progress="20"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Blocked apps will be taken from your current selection."
        android:textColor="#888888" android:textSize="12sp" android:layout_marginTop="12dp"/>
</LinearLayout>
