<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#0A0A0F">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:background="#16161F" android:padding="16dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="📵 Select Apps to Block" android:textColor="#FFFFFF"
            android:textSize="16sp" android:textStyle="bold" android:layout_marginBottom="10dp"/>
        <EditText android:id="@+id/etSearch" android:layout_width="match_parent"
            android:layout_height="44dp" android:hint="Search apps…" android:textColorHint="#5A5A78"
            android:textColor="#FFFFFF" android:textSize="14sp" android:background="#0A0A0F"
            android:paddingHorizontal="12dp" android:inputType="text" android:layout_marginBottom="10dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:id="@+id/tvSelectedCount" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:text="0 selected" android:textColor="#7C6BFF" android:textSize="13sp"
                android:textStyle="bold"/>
            <Button android:id="@+id/btnDone" android:layout_width="wrap_content"
                android:layout_height="36dp" android:text="Done (0)" android:textColor="#FFFFFF"
                android:textSize="13sp" android:backgroundTint="#7C6BFF" android:paddingHorizontal="16dp"/>
        </LinearLayout>
    </LinearLayout>
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvApps"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:paddingBottom="16dp" android:clipToPadding="false"/>
</LinearLayout>
