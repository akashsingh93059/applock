<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#0A0A0F">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="20dp">

        <!-- Big Score -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:gravity="center"
            android:background="#16161F" android:padding="28dp" android:layout_marginBottom="16dp">
            <TextView android:id="@+id/tvScoreGrade"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="—" android:textSize="80sp" android:textStyle="bold"
                android:fontFamily="monospace"/>
            <TextView android:id="@+id/tvScoreTotal"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0 / 100" android:textColor="#AAAACC" android:textSize="20sp"
                android:layout_marginBottom="12dp"/>
            <ProgressBar android:id="@+id/pbScore"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent" android:layout_height="16dp"
                android:progressTint="#7C6BFF" android:progressBackgroundTint="#1E1E2E"
                android:max="100" android:layout_marginBottom="12dp"/>
            <TextView android:id="@+id/tvScoreTip"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#6BFFC8" android:textSize="14sp" android:gravity="center"
                android:lineSpacingMultiplier="1.4"/>
        </LinearLayout>

        <!-- Breakdown -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#16161F" android:padding="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="SCORE BREAKDOWN" android:textColor="#5A5A78"
                android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="16dp"/>

            <TextView android:id="@+id/tvStreakScore" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textColor="#FFFFFF"
                android:textSize="13sp" android:layout_marginBottom="4dp"/>
            <ProgressBar android:id="@+id/pbStreak" style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent" android:layout_height="8dp"
                android:progressTint="#FF6B9D" android:progressBackgroundTint="#1E1E2E"
                android:layout_marginBottom="12dp"/>

            <TextView android:id="@+id/tvSessionScore" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textColor="#FFFFFF"
                android:textSize="13sp" android:layout_marginBottom="4dp"/>
            <ProgressBar android:id="@+id/pbSessions" style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent" android:layout_height="8dp"
                android:progressTint="#7C6BFF" android:progressBackgroundTint="#1E1E2E"
                android:layout_marginBottom="12dp"/>

            <TextView android:id="@+id/tvHoursScore" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textColor="#FFFFFF"
                android:textSize="13sp" android:layout_marginBottom="4dp"/>
            <ProgressBar android:id="@+id/pbHours" style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent" android:layout_height="8dp"
                android:progressTint="#6BFFC8" android:progressBackgroundTint="#1E1E2E"
                android:layout_marginBottom="12dp"/>

            <TextView android:id="@+id/tvTreesScore" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textColor="#FFFFFF"
                android:textSize="13sp" android:layout_marginBottom="4dp"/>
            <ProgressBar android:id="@+id/pbTrees" style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent" android:layout_height="8dp"
                android:progressTint="#66BB6A" android:progressBackgroundTint="#1E1E2E"
                android:layout_marginBottom="12dp"/>

            <TextView android:id="@+id/tvTodayScore" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textColor="#FFFFFF"
                android:textSize="13sp" android:layout_marginBottom="4dp"/>
            <ProgressBar android:id="@+id/pbToday" style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent" android:layout_height="8dp"
                android:progressTint="#FFD700" android:progressBackgroundTint="#1E1E2E"
                android:layout_marginBottom="4dp"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
