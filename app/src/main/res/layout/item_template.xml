<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:gravity="center_vertical"
    android:background="#16161F" android:padding="16dp"
    android:layout_marginBottom="8dp">

    <TextView android:id="@+id/tvTemplateIcon"
        android:layout_width="40dp" android:layout_height="40dp"
        android:text="🎯" android:textSize="24sp" android:gravity="center"/>

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical"
        android:layout_marginStart="12dp">
        <TextView android:id="@+id/tvTemplateName"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvTemplateDesc"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#7C6BFF" android:textSize="12sp" android:layout_marginTop="2dp"/>
    </LinearLayout>

    <Button android:id="@+id/btnApplyTemplate"
        android:layout_width="wrap_content" android:layout_height="36dp"
        android:text="Use" android:textColor="#FFFFFF" android:textSize="12sp"
        android:backgroundTint="#7C6BFF" android:layout_marginEnd="6dp"/>

    <TextView android:id="@+id/btnDeleteTemplate"
        android:layout_width="32dp" android:layout_height="32dp"
        android:text="🗑" android:textSize="16sp" android:gravity="center"/>
</LinearLayout>
