<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/wRoot"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#DD111118"
    android:padding="12dp" android:gravity="center_vertical">

    <TextView android:id="@+id/wStatus"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="▶ Tap to focus" android:textColor="#7C6BFF"
        android:textSize="13sp" android:textStyle="bold" android:layout_marginBottom="6dp"/>

    <TextView android:id="@+id/wStreak"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="🔥 0 day streak" android:textColor="#FFFFFF"
        android:textSize="13sp" android:layout_marginBottom="3dp"/>

    <TextView android:id="@+id/wToday"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="⏱ Today: 0 min" android:textColor="#AAAACC"
        android:textSize="12sp" android:layout_marginBottom="3dp"/>

    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView android:id="@+id/wTrees"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🌳 0" android:textColor="#66BB6A"
            android:textSize="12sp" android:layout_marginEnd="12dp"/>
        <TextView android:id="@+id/wCoins"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🪙 0" android:textColor="#FFD700" android:textSize="12sp"/>
    </LinearLayout>
</LinearLayout>
